// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "./generated"
}

datasource db {
  provider = "postgresql"
}

model Account {
  id         String   @id @default(cuid())
  created_at DateTime @default(now())
  updated_at DateTime @default(now())

  user_id String
  user    User   @relation(fields: [user_id], references: [id], onDelete: Cascade)

  type                String?
  provider            String?
  provider_account_id String?
  refresh_token       String?
  access_token        String?
  expires_at          DateTime?
  token_type          String?
  scope               String?
  id_token            String?
  session_state       String?

  @@unique([provider, provider_account_id])
  @@map("accounts")
}

model User {
  id           String    @id @default(cuid())
  created_at   DateTime  @default(now())
  updated_at   DateTime  @default(now())
  deleted_at   DateTime?
  status       Int?      @default(1) @db.SmallInt
  approved_at  DateTime?
  availability String?

  // Authentication fields
  email        String? @unique
  username     String? @unique
  password     String? @db.VarChar(255)
  phone_number String?

  // Personal info
  name          String?   @db.VarChar(255)
  first_name    String?   @db.VarChar(255)
  last_name     String?   @db.VarChar(255)
  avatar        String?
  gender        String?
  date_of_birth DateTime? @db.Date

  // Location
  country  String?
  state    String?
  city     String?
  address  String?
  zip_code String?
  domain   String? @unique

  // Verification & billing
  email_verified_at DateTime?
  billing_id        String?
  type              String? // Consider changing to enum

  // Two-factor auth
  is_two_factor_enabled Int?    @default(0)
  two_factor_secret     String?

  // Role (CRITICAL - determines if user is Customer or Barber)
  role UserRole? @default(CUSTOMER)

  // Relations to role-specific models
  customer Customer?
  barber   Barber?

  // Other relations
  accounts               Account[]
  receiver_notifications Notification[]       @relation("receiver")
  sender_notifications   Notification[]       @relation("sender")
  user_payment_methods   UserPaymentMethod[]
  user_settings          UserSetting[]
  ucodes                 Ucode[]
  payment_transactions   PaymentTransaction[]

  @@index([email])
  @@index([phone_number])
  @@index([role])
  @@map("users")
}

enum UserRole {
  CUSTOMER
  BARBER
  ADMIN
}

model Customer {
  id            String  @id @default(cuid())
  userId        String  @unique
  proof_address String?
  face_id       String?

  user User @relation(fields: [userId], references: [id])

  preferred_barbers String[]
  hair_preferences  Json?
  allergy_notes     String?

  @@map("customers")
}

model Barber {
  id     String @id @default(cuid())
  userId String @unique

  barber_license   String? @unique
  shop_name        String?
  shop_address     String?
  shop_latitude    Float?
  shop_longitude   Float?
  experience_years Int?    @default(0)
  bio              String? @db.Text
  hourly_rate      Float?
  is_verified      Boolean @default(false)

  proof_address String?
  face_id       String?
  id_documents  IdDocument[]

  portfolio_photos String[]
  working_hours    Json?

  average_rating Float? @default(0.0)
  total_reviews  Int?   @default(0)

  user User @relation(fields: [userId], references: [id])

  avrgRating String?
  totalRating Int @default(0)

  businessHours BusinessHour[]
  services      Service[]

  @@index([shop_name])
  @@index([average_rating])
  @@index([is_verified])
  @@map("barbers")
  reviews Review[]
}

model BusinessHour {
  id        String     @id @default(cuid())
  barberId  String // Foreign key to Barber model
  dayOfWeek DayOfWeek // Enum to store days of the week
  timeSlots TimeSlot[] // One-to-many relationship with time slots
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  barber    Barber     @relation(fields: [barberId], references: [userId]) // Fix relationship to use userId
}

enum DayOfWeek {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

model TimeSlot {
  id             String   @id @default(cuid())
  businessHourId String // Foreign key to BusinessHours
  startTime      DateTime // Time slot start
  endTime        DateTime // Time slot end
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  businessHour BusinessHour @relation(fields: [businessHourId], references: [id])
}

model IdDocument {
  id          String    @id @default(cuid())
  barberId    String
  type        IdType
  document_id String    @unique
  file_url    String?
  verified_at DateTime?
  expires_at  DateTime?

  barber Barber @relation(fields: [barberId], references: [id])

  @@map("id_documents")
}

enum IdType {
  BARBER_LICENSE
  DRIVER_LICENSE
  PASSPORT
  NATIONAL_ID
  OTHER
}

model Service {
  id             String          @id @default(cuid())
  name           String // Name of the service (e.g., "Adult Basic Haircut")
  description    String? // Description (optional)
  category       String // Category (e.g., "Haircuts", "Art Design Services")
  minPrice       Float // Minimum price for the service
  maxPrice       Float // Maximum price for the service
  additionalInfo String? // Additional information like hair enhancements, razor line etc.
  barberId       String // Foreign key to Barber
  barber         Barber          @relation(fields: [barberId], references: [id])
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  serviceOptions ServiceOption[]
  booking Booking[]
}

model ServiceOption {
  id          String   @id @default(cuid())
  name        String // Option name (e.g., "Haircut Style", "Beard Trim")
  description String? // Description of the option, if needed
  serviceId   String // Foreign key to Service
  service     Service  @relation(fields: [serviceId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Booking {
  id   String @id @default(cuid())
  type bookingType
  price Int
  customerLat String
  customerLong String
  barberLat String
  barberLong String
  firstName String?
  workerNote String?
  time DateTime
  serviceId   String
  service Service @relation(fields: [serviceId], references: [id])

  reviews Review[]
}

enum bookingType {
  ON_DEMAND_BARBER
  SCHEDULE_BARBER
}

model Ucode {
  id         String   @id @default(cuid())
  created_at DateTime @default(now())
  updated_at DateTime @default(now())
  status     Int?     @default(1) @db.SmallInt

  user_id String?
  user    User?   @relation(fields: [user_id], references: [id])

  token      String?
  email      String?
  expired_at DateTime?

  @@map("ucodes")
}

// this table stores notification event
model NotificationEvent {
  id         String    @id @default(cuid())
  created_at DateTime  @default(now())
  updated_at DateTime  @default(now())
  deleted_at DateTime?

  status Int?    @default(1) @db.SmallInt
  type   String?
  text   String?

  notifications Notification[]

  @@map("notification_events")
}

model Notification {
  id         String    @id @default(cuid())
  created_at DateTime  @default(now())
  updated_at DateTime  @default(now())
  deleted_at DateTime?

  read_at DateTime?

  status Int? @default(1) @db.SmallInt

  sender_id String?
  sender    User?   @relation("sender", fields: [sender_id], references: [id])

  receiver_id String?
  receiver    User?   @relation("receiver", fields: [receiver_id], references: [id])

  notification_event_id String?
  notification_event    NotificationEvent? @relation(fields: [notification_event_id], references: [id])

  entity_id String?

  @@map("notifications")
}

model Activity{
  id String @id @default(cuid())
  trafficZoneLat Int?
  trafficZoneLong Int?
}

model Review{
  id String @id @default(cuid())
  rating String? 
  comment String?
  image String?
  userId String
  bookingId String
  booking Booking @relation(fields: [bookingId], references: [id])
  barber Barber @relation(fields: [userId], references: [id])
}

model UserPaymentMethod {
  id         String    @id @default(cuid())
  created_at DateTime  @default(now())
  updated_at DateTime  @default(now())
  deleted_at DateTime?

  user_id String?
  user    User?   @relation(fields: [user_id], references: [id])

  payment_method_id String?
  checkout_id       String?

  @@map("user_payment_methods")
}

model PaymentTransaction {
  id         String    @id @default(cuid())
  created_at DateTime  @default(now())
  updated_at DateTime  @default(now())
  deleted_at DateTime?

  store_id String?

  user_id String?
  user    User?   @relation(fields: [user_id], references: [id])

  order_id         String?
  type             String?  @default("order")
  withdraw_via     String?  @default("wallet")
  provider         String?
  reference_number String?
  status           String?  @default("pending")
  raw_status       String?
  amount           Decimal?
  currency         String?
  paid_amount      Decimal?
  paid_currency    String?

  @@map("payment_transactions")
}

// ---------Start Chat schema---------

enum MessageStatus {
  PENDING
  SENT
  DELIVERED
  READ
}

// this table stores attachment of message
model Attachment {
  id         String    @id @default(cuid())
  created_at DateTime  @default(now())
  updated_at DateTime  @default(now())
  deleted_at DateTime?

  name     String?
  type     String?
  size     Int?
  file     String?
  file_alt String?

  @@map("attachments")
}

// ---------End Chat schema---------

model Faq {
  id         String    @id @default(cuid())
  created_at DateTime  @default(now())
  updated_at DateTime  @default(now())
  deleted_at DateTime?

  status     Int?    @default(1) @db.SmallInt
  sort_order Int?    @default(0)
  question   String?
  answer     String?

  @@map("faqs")
}

model Contact {
  id         String    @id @default(cuid())
  created_at DateTime  @default(now())
  updated_at DateTime  @default(now())
  deleted_at DateTime?

  first_name   String?
  last_name    String?
  email        String?
  phone_number String?
  message      String?

  @@map("contacts")
}

model WebsiteInfo {
  id         String    @id @default(cuid())
  created_at DateTime  @default(now())
  updated_at DateTime  @default(now())
  deleted_at DateTime?

  name                String?
  phone_number        String?
  email               String?
  address             String?
  logo                String?
  favicon             String?
  copyright           String?
  cancellation_policy String?

  @@map("website_infos")
}

model Setting {
  id         String    @id @default(cuid())
  created_at DateTime  @default(now())
  updated_at DateTime  @default(now())
  deleted_at DateTime?

  category      String?
  label         String?
  description   String?
  key           String? @unique
  default_value String?

  user_settings UserSetting[]

  @@map("settings")
}

model UserSetting {
  id         String    @id @default(cuid())
  created_at DateTime  @default(now())
  updated_at DateTime  @default(now())
  deleted_at DateTime?

  user_id String?
  user    User?   @relation(fields: [user_id], references: [id])

  setting_id String?
  setting    Setting? @relation(fields: [setting_id], references: [id])

  value String?

  @@map("user_settings")
}
